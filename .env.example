# ─── Hedera ──────────────────────────────────────────────
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_PRIVATE_KEY=YOUR_PRIVATE_KEY

# ─── AI Provider (pick one) ──────────────────────────────
# Groq (free tier — recommended): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key
# OR OpenAI:
# OPENAI_API_KEY=your_openai_api_key

# ─── Policy Configuration ────────────────────────────────
# SpendLimitPolicy
POLICY_MAX_PER_TX=10.0
POLICY_DAILY_LIMIT=100.0

# WhitelistPolicy — comma-separated list of approved Hedera account IDs
POLICY_WHITELIST=0.0.1001,0.0.1002,0.0.1003

# RateLimitPolicy
POLICY_RATE_MAX=10
POLICY_RATE_WINDOW=60

# TimeWindowPolicy — hours in UTC, timezone offset from UTC
POLICY_TIME_START=0
POLICY_TIME_END=24
POLICY_ALLOW_WEEKENDS=true
POLICY_TZ_OFFSET=0

# ─── HCS Audit Trail (optional) ──────────────────────────
# Create a topic first, then put its ID here
HCS_AUDIT_TOPIC_ID=
